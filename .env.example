# 웹 푸시(VAPID) 키 — `node scripts/generate-vapid-keys.mjs` 로 생성
# 로컬: 이 파일을 복사해 .env.local 로 저장하고 값 채우기
# 배포: Vercel 프로젝트 환경변수에 같은 이름으로 등록
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Supabase — 비어 있으면 게임은 '로컬 모드'(localStorage만)로 동작
# 로컬 개발: `npx supabase start` 출력의 API_URL / ANON_KEY
# 배포: Supabase 프로젝트 대시보드 → Settings → API Keys 값으로 교체
#       (Authentication → Sign In / Providers 에서 Anonymous sign-ins 켜기 필수!)
# 키는 두 형식 모두 인식: PUBLISHABLE_KEY(신형 sb_publishable_…) 또는 ANON_KEY(구형 JWT)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 소셜 공유 — OG 카드의 절대 URL 기준 (배포 주소, 예: https://joops.vercel.app)
# 비어 있으면 http://localhost:3000 으로 폴백 (개발용)
NEXT_PUBLIC_SITE_URL=

# 카카오톡 공유 (선택) — developers.kakao.com 앱의 JavaScript 키
# 비어 있으면 카카오톡 버튼은 '링크 복사 + 붙여넣기 안내' 폴백으로 동작
NEXT_PUBLIC_KAKAO_JS_KEY=
