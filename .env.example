# 웹 푸시(VAPID) 키 — `node scripts/generate-vapid-keys.mjs` 로 생성
# 로컬: 이 파일을 복사해 .env.local 로 저장하고 값 채우기
# 배포: Vercel 프로젝트 환경변수에 같은 이름으로 등록
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Supabase — 비어 있으면 게임은 '로컬 모드'(localStorage만)로 동작
# 로컬 개발: `npx supabase start` 출력의 API_URL / ANON_KEY
# 배포: Supabase 프로젝트 대시보드 → Settings → API 값으로 교체
#       (Authentication → Sign In / Up 에서 Anonymous sign-ins 켜기 필수!)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
