# 웹 푸시(VAPID) 키 — `node scripts/generate-vapid-keys.mjs` 로 생성
# 로컬: 이 파일을 복사해 .env.local 로 저장하고 값 채우기
# 배포: Vercel 프로젝트 환경변수에 같은 이름으로 등록
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Supabase — 비어 있으면 게임은 '로컬 모드'(localStorage만)로 동작
# 로컬 개발: `npx supabase start` 출력의 API_URL / ANON_KEY
# 배포: Supabase 프로젝트 대시보드 → Settings → API Keys 값으로 교체
#       (Authentication → Sign In / Providers 에서 Anonymous sign-ins 켜기 필수!)
# 키는 두 형식 모두 인식: PUBLISHABLE_KEY(신형 sb_publishable_…) 또는 ANON_KEY(구형 JWT)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 자동 푸시 알림 (크론 → /api/push/dispatch) ──
# service_role 키: RLS를 우회하는 서버 전용 만능 열쇠 — 절대 NEXT_PUBLIC_ 금지!
# 로컬: `npx supabase status` 출력의 service_role key
# 배포: Supabase 대시보드 → Settings → API Keys 의 secret key
SUPABASE_SERVICE_ROLE_KEY=
# 디스패처 인증 시크릿 (예: `openssl rand -hex 32`로 생성)
# 이 이름(CRON_SECRET) 그대로 두면 Vercel Cron이 자동으로 Bearer 헤더를 붙여준다
CRON_SECRET=
